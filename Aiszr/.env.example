# ===== Aiszr 环境变量配置 =====
# 复制此文件为 .env 并填写实际值

# --- AI 回复引擎 ---
# AI 接口 API Key（用于弹幕回复）
DYSTREAM_API_KEY=dystream-local

# --- 阿里云百炼语音 ---
# 以下三个环境变量任选一个即可，优先级从高到低
DASHSCOPE_API_KEY=
ALIYUN_BAILIAN_API_KEY=
ALIYUN_API_KEY=

# --- 运行时配置（可选，也可通过 runtime.yaml 设置）---
# DYDM_ROOM_ID=
# DYDM_MODEL=rule-based
# DYDM_PERSONA_NAME=助手
# DYDM_PERSONA_STYLE=热情、简洁、直播互动口吻
